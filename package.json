{
  "name": "rebuilt-village",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:rules": "vitest run test/firestore.rules.test.ts",
    "test:rules:emulator": "firebase emulators:exec --only firestore \"npm run test:rules\"",
    "emulators": "firebase emulators:start --only firestore,auth,storage",
    "migrate:fallbacks": "tsx scripts/migrate-fallbacks-to-firestore.ts",
    "build:admin": "npm --prefix admin run build",
    "build:all": "npm run build && npm run build:admin"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.23",
    "firebase": "^12.15.0",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.561.0",
    "marked": "^13.0.3",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-cookie-consent": "^9.0.0",
    "react-dom": "^19.2.3",
    "react-ga4": "^2.1.0",
    "react-router-dom": "^7.10.1",
    "resend": "^6.6.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "axe-core": "^4.11.1",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.10.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.9"
  }
}
